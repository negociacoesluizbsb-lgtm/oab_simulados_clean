{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/create-checkout.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/questoes.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.ts"
    },
    {
      "src": "/api/questoes",
      "dest": "/api/questoes.ts"
    },
    {
      "src": "/questoes.json",
      "dest": "/questoes.json"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
